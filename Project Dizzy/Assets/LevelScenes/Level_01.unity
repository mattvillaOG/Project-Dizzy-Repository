  m_Name: 
  m_EditorClassIdentifier: '::'
  pages:
  - bodyText: 'Dio SPINS clockwise in his office chair! '
    image: {fileID: 0}
  - bodyText: TAP on the screen SHOOT an Air-Blast from Dio's of his blaster
    image: {fileID: 0}
  - bodyText: Airblasts cause Dio to MOVE BACKWARDS in his chair.
    image: {fileID: 0}
  - bodyText: 'GHOST have esscaceped form the paranormal dimenson! '
    image: {fileID: 6705018474736463370, guid: b34443bd8697344ff9fe9b9c7b2fd759, type: 3}
  - bodyText: They will chase down Dizzy man to try to stop him from sipping
    image: {fileID: 0}
  - bodyText: Shoot ghosts with your air blaster to take them out.
    image: {fileID: 0}
  - bodyText: 'Clear all of the ghosts in the room to beat teh level and move on
      to the next round.  '
    image: {fileID: 0}
  bodyTextUI: {fileID: 1878896756107038883}
  imageUI: {fileID: 0}
  nextButton: {fileID: 1710380022}
  backButton: {fileID: 1224570949}
  startButton: {fileID: 3799534320383378899}
  resetOnEnable: 1
