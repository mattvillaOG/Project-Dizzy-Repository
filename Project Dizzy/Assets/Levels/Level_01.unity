  m_EditorClassIdentifier: '::'
  pages:
  - bodyText: 'Dio SPINS clockwise in his office chair! '
    image: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
  - bodyText: TAP on the screen SHOOT an Air Blast from Dio's blaster
    image: {fileID: -7693945976942838975, guid: 28a3e46280e1b4106a3f5eba55fd557b, type: 3}
  - bodyText: Air Blasts cause Dio to MOVE BACKWARDS in his chair.
    image: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
  - bodyText: 'GHOST chase Dio down to try and stop him from spinning! '
    image: {fileID: 6705018474736463370, guid: b34443bd8697344ff9fe9b9c7b2fd759, type: 3}
  - bodyText: Clear ALL  the GHOSTS in the room  to WIN the round and progress to
      the next level! .
    image: {fileID: 6705018474736463370, guid: b34443bd8697344ff9fe9b9c7b2fd759, type: 3}
