  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a9f21eb5e458748858e68dedff53fde8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  pages:
  - bodyText: 'Dio SPINS clockwise in his office chair! '
    image: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
  - bodyText: TAP anywhere on the screen SHOOT Air-Blast.
    image: {fileID: -7693945976942838975, guid: 28a3e46280e1b4106a3f5eba55fd557b, type: 3}
  - bodyText: Air-Blasts make Dio to MOVE BACKWARDS in his chair.
    image: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
  - bodyText: "GHOST will make Dio SPIN SLOWER. \n"
    image: {fileID: 6705018474736463370, guid: b34443bd8697344ff9fe9b9c7b2fd759, type: 3}
  - bodyText: When the chair STOPS spining, it's GAME OVER...
    image: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
  - bodyText: Clear the amount of TOTAL GHOST to WIN the level!
    image: {fileID: 6705018474736463370, guid: b34443bd8697344ff9fe9b9c7b2fd759, type: 3}
  bodyTextUI: {fileID: 5826880002930227353}
  imageUI: {fileID: 910130920951524937}
  nextButton: {fileID: 23349898348861333}
  backButton: {fileID: 5415845951848509997}
  startButton: {fileID: 2061821170014959351}
