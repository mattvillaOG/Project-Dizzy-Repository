    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[4].image
      value: 
      objectReference: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[5].image
      value: 
      objectReference: {fileID: 3816861890334239742, guid: f15e0fc2b125f4e5baa8176d5e9492f4, type: 3}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[0].bodyText
      value: 'Dio SPINS clockwise in his office chair! '
      objectReference: {fileID: 0}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[1].bodyText
      value: TAP on the screen SHOOT an Air-Blast from Dio's of his blaster
      objectReference: {fileID: 0}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[2].bodyText
      value: Airblasts cause Dio to MOVE BACKWARDS in his chair.
      objectReference: {fileID: 0}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[3].bodyText
      value: "GHOST will make Dio SLOW DOWN. \n"
      objectReference: {fileID: 0}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[4].bodyText
      value: When the chair STOPS spining, it's GAME OVER...
      objectReference: {fileID: 0}
    - target: {fileID: 7203256683963867784, guid: 0fae9a66e6e8d49dfb1bd3285aec10f8, type: 3}
      propertyPath: pages.Array.data[5].bodyText
      value: Clear the amount of TOTAL GHOST to win the level!
      objectReference: {fileID: 0}
